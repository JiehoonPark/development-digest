{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ES2022",
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@config/*": ["config/*"]
    },
    "declaration": true,
    "sourceMap": true
  },
  "include": ["src/**/*", "config/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "dist", "data", "logs", "web"]
}
