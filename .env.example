# Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxx

# Resend (이메일)
RESEND_API_KEY=re_xxx

# Reddit OAuth (optional - RSS 대체 가능)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# YouTube Data API
YOUTUBE_API_KEY=

# 수신자 이메일 (쉼표 구분)
DIGEST_RECIPIENTS=your@email.com

# 모드
DRY_RUN=false
LOG_LEVEL=info

# 웹사이트 (GitHub Pages)
SITE_BASE_URL=https://your-username.github.io/dev-digest/
SKIP_TRANSLATION=false

# 옵시디언 Markdown 출력 경로
OBSIDIAN_OUTPUT_DIR=
